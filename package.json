{
  "name": "@jahia/jahia-cli",
  "version": "0.1.0",
  "description": "A CLI to accelerate developing and testing Jahia in the Agentic era",
  "author": "Jahia",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Jahia/jahia-cli",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jahia/jahia-cli.git"
  },
  "bugs": {
    "url": "https://github.com/Jahia/jahia-cli/issues"
  },
  "type": "module",
  "exports": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "jahia-cli": "./bin/run.js"
  },
  "files": [
    "bin",
    "dist",
    "oclif.manifest.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"const fs = require('fs'); ['dist', 'oclif.manifest.json'].forEach(p => fs.rmSync(p, { recursive: true, force: true }))\"",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "postbuild": "oclif manifest",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepack": "npm run clean && npm run build",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.10.1",
    "@oclif/core": "^4",
    "execa": "^9.6.1",
    "js-yaml": "^4.1.1",
    "picomatch": "^4.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@oclif/test": "^4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22",
    "@types/picomatch": "^4.0.3",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9",
    "eslint-config-prettier": "^10",
    "eslint-plugin-functional": "^7",
    "eslint-plugin-prettier": "^5",
    "jiti": "^2.6.1",
    "oclif": "^4",
    "prettier": "^3",
    "tsx": "^4.22.3",
    "typescript": "^5.7",
    "typescript-eslint": "^8.59.1",
    "vitest": "^3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "oclif": {
    "bin": "jahia-cli",
    "dirname": "jahia-cli",
    "commands": {
      "strategy": "pattern",
      "target": "./dist/commands"
    },
    "topicSeparator": " "
  }
}
